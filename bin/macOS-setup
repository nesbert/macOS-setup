#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
SCRIPTS_DIR="${REPO_ROOT}/scripts"

usage() {
  cat <<'EOF'
Usage:
  ./bin/macOS-setup install
  ./bin/macOS-setup update
  ./bin/macOS-setup system-settings
  ./bin/macOS-setup personal-settings
  ./bin/macOS-setup help

Commands:
  install            Bootstrap Homebrew, packages, dotfiles, and DX defaults
  update             Update Homebrew packages/casks and refresh vim config
  system-settings    Apply DX-focused macOS system settings
  personal-settings  Apply personal macOS preferences
  help               Show this help message
EOF
}

main() {
  local command="${1:-help}"

  case "${command}" in
    install)
      exec "${SCRIPTS_DIR}/macOS-install.sh"
      ;;
    update)
      exec "${SCRIPTS_DIR}/macOS-update.sh"
      ;;
    system-settings)
      exec "${SCRIPTS_DIR}/macOS-system-settings.sh"
      ;;
    personal-settings)
      exec "${SCRIPTS_DIR}/macOS-personal-settings.sh"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      echo "Unknown command: ${command}" >&2
      echo >&2
      usage >&2
      exit 1
      ;;
  esac
}

main "$@"
